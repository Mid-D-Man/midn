  delete_files::
    delete_file("crates/midn-core/src/ecs/mod.rs")
    delete_file("crates/midn-core/src/ecs/components.rs")
    delete_file("crates/midn-core/src/ecs/world.rs")
    delete_file("crates/midn-core/src/ecs/registry.rs")
    delete_file("crates/midn-core/src/ecs/systems.rs")


// =============================================================================
// PATCHES — midn-core wiring fixed in place, nothing regenerated
// =============================================================================

  patch_files::

    // ── midn-core/Cargo.toml — add the new dependency ──────────────────────────
    patch_replace_text(
      "crates/midn-core/Cargo.toml",
      "midn-proto = { path = \"../midn-proto\" }\n",
      "midn-proto = { path = \"../midn-proto\" }\nmidn-ecs   = { path = \"../midn-ecs\" }\n"
    )

    // ── mme/state_machine.rs ────────────────────────────────────────────────────

    // 1. imports — drop the inline-storage deps, pull in midn_ecs
    patch_replace_text(
      "crates/midn-core/src/mme/state_machine.rs",
      "use std::borrow::Cow;\nuse std::collections::HashMap;\n\nuse midn_proto::nas::NasSecurityContext;\n\nuse crate::s1ap::S1apMessage;",
      "use std::borrow::Cow;\n\nuse midn_ecs::{ImsiRegistry, World};\n\nuse crate::s1ap::S1apMessage;"
    )

    // 2. delete the dead inline EntityId/AttachContext/SessionState/
    //    TunnelComponent/World/ImsiRegistry block (now lives in midn-ecs)
    patch_replace_block(
      "crates/midn-core/src/mme/state_machine.rs",
      "// ── EntityId ──────────────────────────────────────────────────────────────────",
      "    pub fn lookup(&self, imsi: u64) -> Option<u32> { self.map.get(&imsi).copied() }\n}",
      "// EntityId, AttachContext, SessionState, TunnelComponent, World, and\n// ImsiRegistry now live in the midn-ecs crate (see imports above)."
    )

    // 3. handle_icsrsp — get_tunnel_mut -> tunnel_mut
    patch_replace_text(
      "crates/midn-core/src/mme/state_machine.rs",
      "if let Some(t) = self.world.get_tunnel_mut(entity) {",
      "if let Some(t) = self.world.tunnel_mut(entity) {"
    )

    // 4. handle_release_complete — get_tunnel_mut/get_attach_context -> tunnel/identity
    patch_replace_text(
      "crates/midn-core/src/mme/state_machine.rs",
      "let ul_teid = self.world.get_tunnel_mut(entity).map(|t| t.ul_teid);\n\n        if let Some(ctx) = self.world.get_attach_context(entity) {\n            self.registry.deregister(ctx.imsi);\n        }",
      "let ul_teid = self.world.tunnel(entity).map(|t| t.ul_teid);\n\n        if let Some(identity) = self.world.identity(entity) {\n            self.registry.deregister(identity.imsi);\n        }"
    )

    // 5. handle_uplink_nas — get_attach_context_mut(...).and_then(...) -> nas_security_mut
    patch_replace_text(
      "crates/midn-core/src/mme/state_machine.rs",
      "let nas_ctx = match self.world\n                .get_attach_context_mut(mme_ue_s1ap_id)\n                .and_then(|ctx| ctx.nas_security.as_mut())\n            {",
      "let nas_ctx = match self.world.nas_security_mut(mme_ue_s1ap_id) {"
    )

    // 6. test module — old tests construct AttachContext directly; that type
    //    no longer exists. Bounded, self-contained unit, swapped wholesale.
    patch_replace_block(
      "crates/midn-core/src/mme/state_machine.rs",
      "#[cfg(test)]\nmod tests {",
      "assert_eq!(mme.subscriber_count(), 1, \"subscriber should still be online after protected AttachComplete\");\n    }\n            }",
      "#[cfg(test)]\nmod tests {\n    use super::*;\n    use midn_ecs::{AuthFailReason, AuthState, IdentityComponent, SecurityContext, TunnelComponent};\n    use midn_auth::{AuthKey, OpCode};\n    use midn_auth::keys::{Amf, Rand, Sqn};\n\n    #[test]\n    fn ecs_spawn_with_all_components() {\n        let mut w = World::new();\n        let e = w.spawn();\n        w.insert_identity(e, IdentityComponent { imsi: 1, enb_ue_s1ap_id: 0, ue_ip: [0; 4] });\n        w.insert_security(e, SecurityContext::new_empty());\n        w.set_tunnel(e, TunnelComponent { ul_teid: 0x0001_0000, dl_teid: 0, enb_addr: [0; 4] });\n        assert!(w.identity(e).is_some());\n        assert_eq!(w.subscriber_count(), 1);\n    }\n\n    #[test]\n    fn mme_new_is_phase2() {\n        let mme = Mme::new();\n        assert!(mme.phase3_upf.is_none());\n    }\n\n    #[tokio::test]\n    async fn phase3_wrong_res_rejected_marks_auth_state_and_clears_challenge() {\n        use midn_proto::nas::{encode_attach_request, encode_auth_response};\n        use midn_proto::s1ap::{InitialUeMessage, S1apMessage, UplinkNasTransport};\n\n        let k_buf: [u8; 16] = [0x46,0x5b,0x5c,0xe8,0xb1,0x99,0xb4,0x9f,0xaa,0x5f,0x0a,0x2e,0xe2,0x38,0xa6,0xbc];\n        let opc_buf: [u8; 16] = [0xcd,0x63,0xcb,0x71,0x95,0x4a,0x9f,0x4e,0x48,0xa5,0x99,0x4e,0x37,0xa0,0x2b,0xaf];\n        let imsi = 234_15_0000000001_u64;\n\n        let mut mme = Mme::new().with_phase3([127, 0, 0, 1]);\n        mme.hss.provision(imsi, AuthKey(k_buf), OpCode(opc_buf));\n\n        let (responses, _) = mme.process_s1ap(S1apMessage::InitialUeMessage(InitialUeMessage {\n            enb_ue_s1ap_id: 1,\n            nas_pdu: encode_attach_request(imsi, 1, 0),\n            tai: [0; 5], eutran_cgi: [0; 7], rrc_cause: 1,\n        })).await;\n        let mme_ue_id = match &responses[0] {\n            S1apMessage::DownlinkNasTransport(m) => m.mme_ue_s1ap_id,\n            _ => panic!(),\n        };\n\n        let (responses, events) = mme.process_s1ap(S1apMessage::UplinkNasTransport(UplinkNasTransport {\n            enb_ue_s1ap_id: 1, mme_ue_s1ap_id: mme_ue_id,\n            nas_pdu: encode_auth_response(&[0xAAu8; 8]),\n            tai: [0; 5], eutran_cgi: [0; 7],\n        })).await;\n\n        assert!(responses.is_empty());\n        assert!(events.is_empty());\n        assert_eq!(\n            mme.world.auth_state(mme_ue_id),\n            Some(AuthState::Failed(AuthFailReason::ResMismatch)),\n        );\n        let sec = mme.world.security(mme_ue_id).expect(\"security context must still exist\");\n        assert_eq!(sec.pending_rand, [0u8; 16]);\n        assert_eq!(sec.pending_xres, [0u8; 8]);\n    }\n}"
    )

    // ── mme/attach.rs ────────────────────────────────────────────────────────────

    patch_replace_text(
      "crates/midn-core/src/mme/attach.rs",
      "use crate::mme::state_machine::{\n    AttachContext, ImsiRegistry, SessionState, TeidAllocator, TunnelComponent, UpfEvent, World,\n};",
      "use midn_ecs::{AuthFailReason, AuthState, IdentityComponent, ImsiRegistry, SecurityContext, TunnelComponent, World};\nuse crate::mme::state_machine::{TeidAllocator, UpfEvent};"
    )

    patch_replace_text(
      "crates/midn-core/src/mme/attach.rs",
